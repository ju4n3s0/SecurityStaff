# Shield - Variables de entorno
# Copia este archivo como .env y configura tus valores

# === REQUERIDO ===
# Tu API Key de Google Gemini
# Obtenla en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# === OPCIONAL ===
# Puerto del servidor (default: 5000)
PORT=5000

# Modo debug (default: True para desarrollo)
DEBUG=True

# Clave secreta de Flask (cambia esto en producción)
SECRET_KEY=shield-dev-key-2024